# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=salesai
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/salesai

# OpenAI (optional — system falls back to retrieval-only mode if absent)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Backend
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:19006
LOG_LEVEL=INFO

# Web
VITE_API_BASE_URL=http://localhost:8000

# Mobile (Expo)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
