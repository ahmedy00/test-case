# Backend base URL used by the Expo app at runtime.
#
# Override matrix:
#   - Web target (npx expo start, then `w`): http://localhost:8000
#   - iOS Simulator: http://localhost:8000 (simulator shares host network)
#   - Android Emulator: http://10.0.2.2:8000 (special host alias)
#   - Physical device via Expo Go: http://<your-LAN-IP>:8000
#       Find it with `ifconfig` (mac/linux) or `ipconfig` (Windows),
#       or read it off the dev-server URL in the Expo CLI output.
#
# IMPORTANT: variables consumed by the JS bundle MUST be prefixed
# with EXPO_PUBLIC_ (Expo embeds these at build time).
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
